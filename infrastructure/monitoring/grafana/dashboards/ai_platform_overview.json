{
  "title": "AI Platform — Overview",
  "version": 1,
  "timezone": "utc",
  "panels": [
    {
      "title": "Pipeline Processing Rate",
      "type": "graph",
      "targets": [
        {"expr": "rate(ai_platform_source_processed_total[5m])", "legendFormat": "Processed"},
        {"expr": "rate(ai_platform_source_failed_total[5m])", "legendFormat": "Failed"},
        {"expr": "rate(ai_platform_source_skipped_total[5m])", "legendFormat": "Skipped"}
      ]
    },
    {
      "title": "Processing Time (p95)",
      "type": "graph",
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(ai_platform_processing_time_ms_bucket[5m]))", "legendFormat": "p95"}
      ]
    },
    {
      "title": "Gold Node Creation",
      "type": "graph",
      "targets": [
        {"expr": "rate(ai_platform_nodes_created_total[5m])", "legendFormat": "Nodes/s"},
        {"expr": "rate(ai_platform_edges_created_total[5m])", "legendFormat": "Edges/s"}
      ]
    },
    {
      "title": "Data Contract Violations",
      "type": "graph",
      "targets": [
        {"expr": "rate(ai_platform_contract_violations_total[5m])", "legendFormat": "Violations/s"}
      ]
    },
    {
      "title": "Schema Violations",
      "type": "graph",
      "targets": [
        {"expr": "rate(ai_platform_schema_violations_total[5m])", "legendFormat": "By table"}
      ]
    },
    {
      "title": "Gold Embedding Health",
      "type": "stat",
      "targets": [
        {"expr": "ai_platform_gold_nodes_total - ai_platform_gold_nodes_without_embedding", "legendFormat": "With embedding"},
        {"expr": "ai_platform_gold_nodes_without_embedding", "legendFormat": "Without embedding"}
      ]
    },
    {
      "title": "RAG Corpus Freshness",
      "type": "graph",
      "targets": [
        {"expr": "rag_corpus_freshness_hours", "legendFormat": "Hours since last index"}
      ]
    },
    {
      "title": "RAG Embedding Drift",
      "type": "graph",
      "targets": [
        {"expr": "rag_embedding_mean_shift", "legendFormat": "Mean shift"},
        {"expr": "rag_embedding_max_psi", "legendFormat": "Max PSI"}
      ]
    },
    {
      "title": "Agent Hallucination Score",
      "type": "graph",
      "targets": [
        {"expr": "agent_hallucination_score", "legendFormat": "Score"}
      ]
    },
    {
      "title": "Agent Execution Latency (p95)",
      "type": "graph",
      "targets": [
        {"expr": "histogram_quantile(0.95, rate(agent_execution_latency_ms_bucket[5m]))", "legendFormat": "p95"}
      ]
    },
    {
      "title": "Agent Cost ($/hour)",
      "type": "graph",
      "targets": [
        {"expr": "rate(agent_total_cost_usd_total[1h])", "legendFormat": "$/hour"}
      ]
    },
    {
      "title": "DB Connection Pool",
      "type": "graph",
      "targets": [
        {"expr": "db_pool_checkedout", "legendFormat": "Checked out"},
        {"expr": "db_pool_size", "legendFormat": "Pool size"}
      ]
    }
  ]
}
