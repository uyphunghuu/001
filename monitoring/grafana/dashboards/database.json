{
  "title": "Database Dashboard",
  "version": 1,
  "timezone": "utc",
  "editable": true,
  "refresh": "15s",
  "tags": ["database", "postgresql", "ai-platform"],
  "panels": [
    {
      "title": "Connection Overview",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "title": "Active Connections",
      "type": "graph",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 1},
      "targets": [
        {"expr": "pg_stat_activity_count", "legendFormat": "Active"},
        {"expr": "pg_stat_activity_max_connections", "legendFormat": "Max"},
        {"expr": "pg_stat_activity_count / pg_settings_max_connections * 100", "legendFormat": "% Used"}
      ]
    },
    {
      "title": "Connection by State",
      "type": "graph",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 1},
      "targets": [
        {"expr": "pg_stat_activity_count{state='active'}", "legendFormat": "Active"},
        {"expr": "pg_stat_activity_count{state='idle'}", "legendFormat": "Idle"},
        {"expr": "pg_stat_activity_count{state='idle in transaction'}", "legendFormat": "Idle in TX"}
      ]
    },
    {
      "title": "Connection Pool Usage",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 1},
      "targets": [
        {"expr": "pg_stat_activity_count / pg_settings_max_connections * 100"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "max": 100, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 60}, {"color": "red", "value": 80}]}}}
    },
    {
      "title": "Query Performance",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9}
    },
    {
      "title": "Query Duration",
      "type": "graph",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 10},
      "targets": [
        {"expr": "rate(pg_stat_activity_query_duration_seconds_sum[5m]) / rate(pg_stat_activity_query_duration_seconds_count[5m])", "legendFormat": "Avg"},
        {"expr": "histogram_quantile(0.95, rate(pg_stat_activity_query_duration_seconds_bucket[5m]))", "legendFormat": "p95"}
      ]
    },
    {
      "title": "Transactions",
      "type": "graph",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 10},
      "targets": [
        {"expr": "rate(pg_stat_database_xact_commit[5m])", "legendFormat": "Committed"},
        {"expr": "rate(pg_stat_database_xact_rollback[5m])", "legendFormat": "Rollback"}
      ]
    },
    {
      "title": "Locks & Deadlocks",
      "type": "graph",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 10},
      "targets": [
        {"expr": "pg_locks_count", "legendFormat": "Total locks"},
        {"expr": "rate(pg_stat_database_deadlocks[5m])", "legendFormat": "Deadlocks/s"}
      ]
    },
    {
      "title": "Storage & Cache",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18}
    },
    {
      "title": "Database Size",
      "type": "graph",
      "gridPos": {"h": 8, "w": 6, "x": 0, "y": 19},
      "targets": [
        {"expr": "pg_database_size_bytes{datname='ai_platform'}", "legendFormat": "Size"}
      ]
    },
    {
      "title": "Cache Hit Ratio",
      "type": "graph",
      "gridPos": {"h": 8, "w": 6, "x": 6, "y": 19},
      "targets": [
        {"expr": "(sum(rate(pg_stat_database_blks_hit[5m])) / (sum(rate(pg_stat_database_blks_read[5m])) + sum(rate(pg_stat_database_blks_hit[5m])))) * 100", "legendFormat": "Hit %"}
      ]
    },
    {
      "title": "Index vs Seq Scans",
      "type": "graph",
      "gridPos": {"h": 8, "w": 6, "x": 12, "y": 19},
      "targets": [
        {"expr": "rate(pg_stat_user_indexes_idx_scan[5m])", "legendFormat": "Index scans"},
        {"expr": "rate(pg_stat_user_tables_seq_scan[5m])", "legendFormat": "Seq scans"}
      ]
    },
    {
      "title": "Table Size Top 10",
      "type": "table",
      "gridPos": {"h": 8, "w": 6, "x": 18, "y": 19},
      "targets": [{"expr": "topk(10, pg_total_relation_size_bytes)", "legendFormat": "", "format": "table"}],
      "transformations": [{"id": "organize", "options": {"excludeByName": {}, "renameByName": {"datname": "Table", "Value": "Size"}}}]
    },
    {
      "title": "Vacuum & Maintenance",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 27}
    },
    {
      "title": "Vacuum Operations",
      "type": "graph",
      "gridPos": {"h": 6, "w": 8, "x": 0, "y": 28},
      "targets": [
        {"expr": "rate(pg_stat_user_tables_n_tup_deleted[5m])", "legendFormat": "Deleted"},
        {"expr": "rate(pg_stat_user_tables_n_tup_updated[5m])", "legendFormat": "Updated"},
        {"expr": "rate(pg_stat_user_tables_n_tup_inserted[5m])", "legendFormat": "Inserted"}
      ]
    },
    {
      "title": "Dead Tuples",
      "type": "graph",
      "gridPos": {"h": 6, "w": 8, "x": 8, "y": 28},
      "targets": [
        {"expr": "pg_stat_user_tables_n_dead_tup", "legendFormat": "{{.relname}}"}
      ]
    }
  ]
}
