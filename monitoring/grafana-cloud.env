# Grafana Cloud credentials
# Get these from: https://grafana.com → My Account → Grafana Cloud → Details
# Free tier: 10k metrics, 50GB logs, 14d retention
GC_PROM_URL=https://prometheus-prod-us-central-0.grafana.net/api/prom/push
GC_LOKI_URL=https://logs-prod-us-central-0.grafana.net/loki/api/v1/push
GC_TEMPO_URL=https://tempo-prod-us-central-0.grafana.net/tempo
GC_USERNAME=your-grafana-cloud-instance-id  # Numbers like 123456
GC_API_KEY=your-grafana-cloud-api-key       # Create at grafana.com/org/access-policies
GC_PROM_USER=123456
GC_LOKI_USER=123456
GC_TEMPO_USER=123456
